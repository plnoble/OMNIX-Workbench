{
  "name": "omnix-workbench",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:build:msi": "tauri build --bundles msi",
    "tauri:build:nsis": "tauri build --bundles nsis",
    "diagnose:msi": "powershell -ExecutionPolicy Bypass -File scripts/diagnose-msi.ps1",
    "repair:msi-env": "powershell -ExecutionPolicy Bypass -File scripts/repair-msi-environment.ps1",
    "test:lib": "cd src-tauri && cargo test --lib",
    "test:integration": "cd src-tauri && cargo test --lib -- --ignored"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
