{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OMNIX Workbench",
  "version": "0.13.2",
  "identifier": "com.omnix.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OMNIX Workbench",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' asset: http://asset.localhost https: data: blob:; media-src 'self' asset: http://asset.localhost data: blob:; connect-src 'self' https: http://localhost:11434 http://localhost:8080 http://127.0.0.1:1421; frame-src https:; worker-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.omnix/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "upgradeCode": "1339290b-b4f1-5e65-b4b9-f8b0141ebc54"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5RDIwNzgzN0RCNDI1NUUKUldSZUpiUjlnd2ZTMmJvTi9PdHlGOHg4cjhKUU1JaGllYm9SaTh1UVJhM3hBTFA4aFNOVlZvMnYK",
      "endpoints": [
        "https://github.com/plnoble/OMNIX-Workbench/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
