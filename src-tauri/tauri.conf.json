{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "omnix-app",
  "version": "0.1.0",
  "identifier": "com.tauri-app.omnix-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OMNIX DevFlow",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' asset: https: data: blob:; connect-src 'self' https: http://localhost:11434 http://localhost:8080 http://127.0.0.1:1421; frame-src https:; worker-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "upgradeCode": "1339290b-b4f1-5e65-b4b9-f8b0141ebc54"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
